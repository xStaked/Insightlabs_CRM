        {
          "name": "Create Automation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Qualified Follow Up\",\n  \"trigger_type\": \"lead.stage_changed\",\n  \"conditions\": [\n    {\n      \"field\": \"current_stage_id\",\n      \"op\": \"eq\",\n      \"value\": \"{{stageId}}\"\n    }\n  ],\n  \"actions\": [\n    {\n      \"type\": \"create_task\",\n      \"task_type\": \"follow_up\",\n      \"priority\": \"high\",\n      \"delay_hours\": 2\n    },\n    {\n      \"type\": \"score\",\n      \"points\": 20,\n      \"reason\": \"Reached qualified\"\n    }\n  ],\n  \"is_active\": true\n}"
            },
            "url": "{{baseUrl}}/automations"
          }
        },
