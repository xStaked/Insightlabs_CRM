            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Qualified Follow Up v2\",\n  \"is_active\": true,\n  \"conditions\": [\n    {\n      \"field\": \"current_stage_id\",\n      \"op\": \"eq\",\n      \"value\": \"{{stageId}}\"\n    }\n  ],\n  \"actions\": [\n    {\n      \"type\": \"tag\",\n      \"name\": \"qualified\",\n      \"color\": \"#0f766e\"\n    }\n  ]\n}"
