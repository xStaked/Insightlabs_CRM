    {
      "name": "Webhooks",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Meta Challenge",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/webhooks/meta?hub.mode=subscribe&hub.verify_token=CHANGE_ME&hub.challenge=123456",
              "host": ["{{baseUrl}}"],
              "path": ["webhooks", "meta"],
              "query": [
                { "key": "hub.mode", "value": "subscribe" },
                { "key": "hub.verify_token", "value": "CHANGE_ME" },
                { "key": "hub.challenge", "value": "123456" }
              ]
            }
          }
        },
        {
          "name": "Meta Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Hub-Signature-256", "value": "sha256=CHANGE_ME" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entry\": [\n    {\n      \"changes\": [\n        {\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"contacts\": [\n              {\n                \"profile\": {\n                  \"name\": \"Sofia Ramirez\"\n                }\n              }\n            ],\n            \"messages\": [\n              {\n                \"from\": \"+573001112233\",\n                \"id\": \"wamid.HBgMNTczMDAxMTEyMjMzFQIAEhggRkE0\",\n                \"text\": {\n                  \"body\": \"Hola\"\n                }\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/webhooks/meta"
          }
        },
        {
          "name": "Wompi Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Wompi-Signature", "value": "CHANGE_ME" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"transaction.updated\",\n  \"data\": {\n    \"transaction\": {\n      \"id\": \"txn_demo_123\",\n      \"status\": \"APPROVED\"\n    }\n  }\n}"
            },
            "url": "{{baseUrl}}/webhooks/wompi"
          }
        }
      ]
    }
